{
  "name": "clap",
  "version": "1.0.0",
  "description": "Clap! is web application to create storyboard and videos script for an educational purpose.",
  "author": "Par Le Monde",
  "license": "GPL-3.0-only",
  "main": "dist/server/app.js",
  "scripts": {
    "copy:templates": "yarn cpx 'server/pdf/templates/*' 'dist/server/pdf/templates' && yarn cpx 'server/emails/templates/*' 'dist/server/emails/templates'",
    "copy:swagger": "yarn cpx \"server/**/*.yaml\" dist/server",
    "copy:pwa": "yarn cpx dist/next/workbox-*.js public && yarn cpx dist/next/sw.js public",
    "build:next": "next build && yarn copy:pwa",
    "build:server": "swc ./server -d dist/server && swc ./types -d dist/types && yarn copy:templates && yarn copy:swagger",
    "build": "rm -rf dist && NODE_ENV=production yarn build:next && yarn build:server",
    "lint": "yarn eslint src && yarn eslint server",
    "typescript": "yarn tsc -p . && yarn typescript:server",
    "typescript:server": "yarn tsc --project server/tsconfig.json",
    "start": "NODE_ENV=production node dist/server/app.js",
    "start-dev": "yarn build:server && node dist/server/app.js",
    "dev": "nodemon --watch server --ext ts,yaml,json,html,pug --exec yarn start-dev"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.54.1",
    "@emotion/cache": "^11.7.1",
    "@emotion/react": "^11.8.1",
    "@emotion/server": "^11.4.0",
