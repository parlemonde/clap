{
  "name": "clap",
  "version": "1.0.0",
  "private": true,
  "description": "Clap! is an innovative web application that simplifies video creation in educational settings. Teachers can create themes and scenarios, while students can collaborate in real-time to build storyboards and generate videos using a guided workflow.",
  "author": "Par Le Monde",
  "license": "GPL-3.0-or-later",
  "homepage": "https://clap.parlemonde.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/parlemonde/clap"
  },
  "scripts": {
    "dev:next": "next dev",
    "dev:websockets": "node server-websockets/app.js",
    "dev:services": "docker compose up",
    "dev:email": "email dev --port 3001 --dir ./src/server/emails/templates",
    "dev": "concurrently --names nextjs,websockets,docker -c green,yellow,blue --kill-others-on-fail \"pnpm run dev:next\" \"pnpm run dev:websockets\" \"pnpm run dev:services\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit -p .",
    "db:migrate": "tsx src/server/database/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@better-auth/utils": "^0.4.0",
    "@node-rs/argon2": "2.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.215.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation-pg": "^0.67.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@vercel/otel": "^2.1.2",
    "archiver": "^7.0.1",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.6",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fast-deep-equal": "^3.1.3",
    "fs-extra": "^11.3.0",
    "jose": "^6.0.12",
    "mediabunny": "^1.41.0",
    "mime-types": "^3.0.1",
    "mlt-xml": "^2.0.2",
    "next": "16.2.4",
    "next-intl": "4.11.0",
    "nodemailer": "^8.0.5",
    "normalize.css": "^8.0.1",
    "nprogress": "^0.2.0",
    "nuqs": "^2.8.9",
    "pg": "^8.20.0",
    "pug": "^3.0.3",
    "puppeteer": "^24.42.0",
    "radix-ui": "^1.4.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-email": "^6.0.0",
    "react-html5-camera-photo": "^1.5.11",
    "sanitize-filename": "^1.6.3",
    "sharp": "0.34.5",
    "sortablejs": "^1.15.6",
    "swr": "^2.3.4",
    "uuid": "^14.0.0",
    "waveform-data": "^4.5.2"
  },
  "devDependencies": {
    "@eslint/css": "^1.0.0",
    "@eslint/js": "9.39.4",
    "@eslint/json": "^1.2.0",
    "@next/eslint-plugin-next": "16.2.4",
    "@react-email/ui": "^6.0.0",
    "@svgr/webpack": "8.1.0",
    "@types/archiver": "7.0.0",
    "@types/fs-extra": "11.0.4",
    "@types/mime-types": "3.0.1",
    "@types/node": "25.6.0",
    "@types/nodemailer": "8.0.0",
    "@types/nprogress": "0.2.3",
    "@types/pg": "^8.20.0",
    "@types/pug": "2.0.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-html5-camera-photo": "1.5.5",
    "@types/sortablejs": "1.15.9",
    "concurrently": "^9.2.1",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "prettier": "3.8.3",
    "raw-loader": "4.0.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2"
  },
  "volta": {
    "node": "22.15.1"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "protobufjs",
      "puppeteer",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
