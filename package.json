    "axios": "^0.26.0",
    "base64url": "^3.0.1",
    "body-parser": "^1.19.2",
    "classnames": "^2.3.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "croppie": "^2.6.5",
    "csrf": "^3.1.0",
    "dotenv": "^16.0.0",
    "express": "^4.17.3",
    "fs-extra": "^10.0.0",
    "helmet": "^5.0.2",
    "json-stable-stringify": "^1.0.1",
    "jsonwebtoken": "^8.5.1",
